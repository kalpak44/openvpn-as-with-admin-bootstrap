# Required
OPENVPN_ADMIN_USERNAME=admin
OPENVPN_ADMIN_PASSWORD=change-me-now

# Optional
OPENVPN_BOOTSTRAP_ADMIN=true
OPENVPN_BOOTSTRAP_TIMEOUT_SECONDS=120

# Optional persistence marker behavior
# true  = bootstrap once and never touch admin again unless data is wiped
# false = re-apply admin password/role on every container start
OPENVPN_BOOTSTRAP_ONCE=true